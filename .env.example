# Copy this file to .env and fill in real values. NEVER commit .env to git.

# From Railway PostgreSQL service -> Variables -> DATABASE_PUBLIC_URL
DATABASE_URL=postgresql://user:password@host:port/railway

# Any long random string (e.g. run: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=put-a-long-random-string-here

# Head Coach account (auto-created on first startup)
HEADCOACH_EMAIL=rj@aitamate.com
HEADCOACH_PASSWORD=choose-a-strong-password
HEADCOACH_NAME=RJ

# Needed only from Phase 4 onwards
ANTHROPIC_API_KEY=
